    "registry_path": "profiles/index.json",
    "primary_entrypoint": "profiles/asiep/v0.1/profile.json",
    "agent_tasks": [
      "validate evidence object",
      "interpret validation errors",
      "generate evidence-preserving repair plan",
      "resolve local evidence bundle",
      "verify local artifact digests",
      "import local trace fixture into ASIEP evidence bundle",
      "package ASIEP evidence bundle into local FDO-like and RO-Crate-like package",
      "evaluate local corpus and generate paper-ready evidence assets",
      "inspect paper claims and evidence bindings",
      "lint paper overclaims",
      "inspect external source registry",
      "lint paper citations",
      "check venue readiness",
      "check eScience human rewrite package",
      "lint submission package",
      "track human rewrite progress",
      "run final submission gates",
      "revalidate after repair",
      "route cross-standard mapping"
    ],
