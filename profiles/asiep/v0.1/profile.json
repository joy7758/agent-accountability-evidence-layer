    "json_command_template": "PYTHONPATH=src python -m asiep_citation_linter --profile profiles/asiep/v0.1/profile.json --format json"
  },
  "examples": {
    "valid_examples": [
      {
        "path": "examples/valid_chatbot_improvement.json",
        "expected_text_codes": ["VALID"],
        "expected_json_valid": true
      }
    ],
    "invalid_examples": [
      {
        "path": "examples/invalid_missing_gate_report.json",
        "expected_text_codes": ["SCHEMA"],
