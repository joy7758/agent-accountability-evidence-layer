  "validator_entrypoint": {
    "module": "asiep_validator",
    "cli": "python -m asiep_validator",
    "default_output_format": "text",
    "agent_output_format": "json",
    "json_command_template": "PYTHONPATH=src python -m asiep_validator {evidence_path} --format json"
  },
  "repairer_entrypoint": {
    "module": "asiep_repairer",
    "cli": "python -m asiep_repairer",
    "default_output_format": "json",
    "json_command_template": "PYTHONPATH=src python -m asiep_repairer {evidence_path} --format json",
    "output_command_template": "PYTHONPATH=src python -m asiep_repairer {evidence_path} --format json --output {repair_plan_path}"
  },
  "resolver_entrypoint": {
    "module": "asiep_resolver",
    "cli": "python -m asiep_resolver",
    "default_output_format": "text",
    "agent_output_format": "json",
    "json_command_template": "PYTHONPATH=src python -m asiep_resolver {bundle_path} --format json"
  },
  "importer_entrypoint": {
    "module": "asiep_importer",
    "cli": "python -m asiep_importer",
    "default_output_format": "text",
    "agent_output_format": "json",
    "json_command_template": "PYTHONPATH=src python -m asiep_importer {import_request_path} --format json"
  },
  "packager_entrypoint": {
    "module": "asiep_packager",
    "cli": "python -m asiep_packager",
    "default_output_format": "text",
    "agent_output_format": "json",
    "json_command_template": "PYTHONPATH=src python -m asiep_packager {package_request_path} --format json"
  },
  "evaluator_entrypoint": {
    "module": "asiep_evaluator",
    "cli": "python -m asiep_evaluator",
    "default_output_format": "text",
    "agent_output_format": "json",
    "json_command_template": "PYTHONPATH=src python -m asiep_evaluator --profile profiles/asiep/v0.1/profile.json --format json"
  },
  "paper_linter_entrypoint": {
    "module": "asiep_paper_linter",
    "cli": "python -m asiep_paper_linter",
    "default_output_format": "text",
    "agent_output_format": "json",
