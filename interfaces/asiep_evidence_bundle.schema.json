{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/asiep/v0.1/interfaces/asiep_evidence_bundle.schema.json",
  "title": "ASIEP Evidence Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_id",
    "profile",
    "profile_version",
    "bundle_version",
    "created_at",
    "evidence_record_path",
    "bundle_root",
    "artifacts",
    "access_policy",
    "redaction_policy",
    "integrity"
  ],
  "properties": {
    "bundle_id": {
      "type": "string",
      "pattern": "^bundle:[A-Za-z0-9._:-]+$"
    },
    "profile": { "const": "ASIEP" },
    "profile_version": { "const": "0.1.0" },
    "bundle_version": { "const": "0.1.0" },
    "created_at": { "type": "string", "format": "date-time" },
    "evidence_record_path": { "$ref": "#/$defs/relative_path" },
    "bundle_root": {
      "type": "string",
      "minLength": 1
    },
    "artifacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact" },
      "uniqueItems": true
    },
    "access_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["classification", "allowed_resolvers"],
      "properties": {
        "classification": { "type": "string", "minLength": 1 },
        "allowed_resolvers": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "network_access": { "const": false }
      }
    },
    "redaction_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contains_redactions", "redaction_summary"],
      "properties": {
        "contains_redactions": { "type": "boolean" },
        "redaction_summary": { "type": "string" }
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bundle_manifest_hash", "hash_algorithm"],
      "properties": {
        "bundle_manifest_hash": { "$ref": "#/$defs/digest" },
        "hash_algorithm": { "const": "sha256" }
      }
    }
  },
  "$defs": {
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-fA-F0-9]{64}$"
    },
    "relative_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/).+$"
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_id",
        "uri",
        "path",
        "media_type",
        "digest",
        "role",
        "required"
      ],
      "properties": {
        "artifact_id": {
          "type": "string",
          "pattern": "^artifact:[A-Za-z0-9._:-]+$"
        },
        "uri": { "type": "string", "minLength": 1 },
        "path": { "$ref": "#/$defs/relative_path" },
        "media_type": { "type": "string", "minLength": 1 },
        "digest": { "$ref": "#/$defs/digest" },
        "role": {
          "type": "string",
          "enum": [
            "trace",
            "feedback",
            "score",
            "diagnosis",
            "candidate_diff",
            "gate_report",
            "incident",
            "monitoring",
            "approval",
            "rollback",
            "other"
          ]
        },
        "required": { "type": "boolean" }
      }
    }
  }
}
