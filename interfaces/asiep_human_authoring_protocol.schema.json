{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/asiep/interfaces/asiep_human_authoring_protocol.schema.json",
  "title": "ASIEP Human Authoring Protocol",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "protocol_id",
    "protocol_version",
    "target_venue",
    "paper_id",
    "paper_version",
    "created_at",
    "human_rewrite_required",
    "final_submission_ready",
    "author_verify_marker",
    "ai_systems_used",
    "ieee_ai_disclosure_requirements",
    "section_rewrite_plan",
    "required_author_actions",
    "forbidden_actions",
    "completion_criteria",
    "verification_sources"
  ],
  "properties": {
    "protocol_id": { "type": "string", "minLength": 1 },
    "protocol_version": { "type": "string", "minLength": 1 },
    "target_venue": { "type": "string", "minLength": 1 },
    "paper_id": { "type": "string", "minLength": 1 },
    "paper_version": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "human_rewrite_required": { "type": "boolean" },
    "final_submission_ready": { "type": "boolean" },
    "author_verify_marker": { "type": "string", "minLength": 1 },
    "ai_systems_used": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["system_name", "use_locations", "use_level", "human_verification_required"],
        "properties": {
          "system_name": { "type": "string", "minLength": 1 },
          "use_locations": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "use_level": { "type": "string", "minLength": 1 },
          "human_verification_required": { "type": "boolean" }
        }
      }
    },
    "ieee_ai_disclosure_requirements": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "acknowledgements_disclosure_required",
        "identify_ai_system",
        "identify_sections",
        "describe_level_of_use",
        "state_author_responsibility"
      ],
      "properties": {
        "acknowledgements_disclosure_required": { "type": "boolean" },
        "identify_ai_system": { "type": "boolean" },
        "identify_sections": { "type": "boolean" },
        "describe_level_of_use": { "type": "boolean" },
        "state_author_responsibility": { "type": "boolean" }
      }
    },
    "section_rewrite_plan": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["section_id", "source_path", "required_action", "evidence_refs", "author_verify_required"],
        "properties": {
          "section_id": { "type": "string", "minLength": 1 },
          "source_path": { "type": "string", "minLength": 1 },
          "required_action": { "type": "string", "minLength": 1 },
          "evidence_refs": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "author_verify_required": { "type": "boolean" }
        }
      }
    },
    "required_author_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "forbidden_actions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "completion_criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "verification_sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_id", "url", "human_verification_required"],
        "properties": {
          "source_id": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "minLength": 1 },
          "human_verification_required": { "type": "boolean" }
        }
      }
    }
  }
}
