{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/asiep/v0.1/interfaces/asiep_evaluation_report.schema.json",
  "title": "ASIEP Evaluation Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profile",
    "profile_version",
    "evaluation_id",
    "evaluation_version",
    "created_at",
    "repository",
    "evaluated_components",
    "corpus_summary",
    "pipeline_results",
    "metric_results",
    "attack_corpus_results",
    "crosswalk_coverage",
    "generated_artifacts",
    "limitations",
    "revalidation_commands"
  ],
  "properties": {
    "profile": { "const": "ASIEP" },
    "profile_version": { "const": "0.1.0" },
    "evaluation_id": { "type": "string", "minLength": 1 },
    "evaluation_version": { "const": "0.1.0" },
    "created_at": { "type": "string", "format": "date-time" },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "root", "commit"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "root": { "type": "string", "minLength": 1 },
        "commit": { "type": "string" }
      }
    },
    "evaluated_components": {
      "type": "array",
      "items": { "$ref": "#/$defs/component" }
    },
    "corpus_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total_expected_results", "valid_targets", "invalid_targets", "target_types"],
      "properties": {
        "total_expected_results": { "type": "integer", "minimum": 0 },
        "valid_targets": { "type": "integer", "minimum": 0 },
        "invalid_targets": { "type": "integer", "minimum": 0 },
        "target_types": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "pipeline_results": {
      "type": "array",
      "items": { "$ref": "#/$defs/pipeline_result" }
    },
    "metric_results": {
      "type": "array",
      "minItems": 8,
      "items": { "$ref": "#/$defs/metric" }
    },
    "attack_corpus_results": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total_attack_samples", "detected_attack_samples", "results"],
      "properties": {
        "total_attack_samples": { "type": "integer", "minimum": 0 },
        "detected_attack_samples": { "type": "integer", "minimum": 0 },
        "results": {
          "type": "array",
          "items": { "$ref": "#/$defs/pipeline_result" }
        }
      }
    },
    "crosswalk_coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field_group_count",
        "standards_count",
        "mapped_cells",
        "total_cells",
        "coverage",
        "invariant_coverage"
      ],
      "properties": {
        "field_group_count": { "type": "integer", "minimum": 0 },
        "standards_count": { "type": "integer", "minimum": 0 },
        "mapped_cells": { "type": "integer", "minimum": 0 },
        "total_cells": { "type": "integer", "minimum": 0 },
        "coverage": { "type": "number", "minimum": 0, "maximum": 1 },
        "invariant_coverage": {
          "type": "object",
          "additionalProperties": { "type": "boolean" }
        }
      }
    },
    "generated_artifacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/generated_artifact" }
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "revalidation_commands": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["component_id", "path", "status"],
      "properties": {
        "component_id": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "status": { "enum": ["present", "generated", "missing"] }
      }
    },
    "pipeline_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_path",
        "target_type",
        "command",
        "expected_valid",
        "actual_valid",
        "expected_error_codes",
        "actual_error_codes",
        "passed",
        "purpose",
        "related_invariant_ids",
        "related_metric_ids"
      ],
      "properties": {
        "target_path": { "type": "string", "minLength": 1 },
        "target_type": { "type": "string", "minLength": 1 },
        "command": { "type": "string", "minLength": 1 },
        "expected_valid": { "type": "boolean" },
        "actual_valid": { "type": "boolean" },
        "expected_error_codes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "actual_error_codes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "passed": { "type": "boolean" },
        "purpose": { "type": "string", "minLength": 1 },
        "related_invariant_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "related_metric_ids": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "metric": {
      "type": "object",
      "additionalProperties": false,
      "required": ["metric_id", "name", "value", "numerator", "denominator", "method", "interpretation", "limitations"],
      "properties": {
        "metric_id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "value": { "type": "number", "minimum": 0 },
        "numerator": { "type": "number", "minimum": 0 },
        "denominator": { "type": "number", "minimum": 0 },
        "method": { "type": "string", "minLength": 1 },
        "interpretation": { "type": "string", "minLength": 1 },
        "limitations": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "generated_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "artifact_type"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "artifact_type": { "type": "string", "minLength": 1 }
      }
    }
  }
}
