{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/asiep/v0.1/interfaces/otel_genai_trace_fixture.schema.json",
  "title": "Minimal OTel GenAI-like Trace Fixture",
  "type": "object",
  "additionalProperties": true,
  "required": ["trace_id", "spans"],
  "properties": {
    "trace_id": { "type": "string", "minLength": 1 },
    "spans": {
      "type": "array",
      "items": { "$ref": "#/$defs/span" }
    }
  },
  "$defs": {
    "span": {
      "type": "object",
      "additionalProperties": false,
      "required": ["span_id", "parent_span_id", "name", "kind", "start_time", "end_time", "attributes", "events"],
      "properties": {
        "span_id": { "type": "string", "minLength": 1 },
        "parent_span_id": { "type": ["string", "null"] },
        "name": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "start_time": { "type": "string", "format": "date-time" },
        "end_time": { "type": "string", "format": "date-time" },
        "attributes": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "gen_ai.operation.name": { "type": "string" },
            "gen_ai.agent.id": { "type": "string" },
            "gen_ai.agent.name": { "type": "string" },
            "gen_ai.agent.version": { "type": "string" },
            "gen_ai.conversation.id": { "type": "string" },
            "gen_ai.request.model": { "type": "string" },
            "gen_ai.response.model": { "type": "string" },
            "gen_ai.tool.name": { "type": "string" },
            "gen_ai.data_source.id": { "type": "string" },
            "asiep.role": {
              "enum": ["trace", "feedback", "score", "diagnosis", "candidate_diff", "gate_report", "incident", "monitoring", "approval", "rollback"]
            }
          }
        },
        "events": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["name", "time", "attributes"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "time": { "type": "string", "format": "date-time" },
              "attributes": { "type": "object", "additionalProperties": true }
            }
          }
        }
      }
    }
  }
}
