{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/asiep/interfaces/asiep_source_registry.schema.json",
  "title": "ASIEP External Source Registry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "registry_id",
    "registry_version",
    "created_at",
    "verification_mode",
    "sources"
  ],
  "properties": {
    "registry_id": { "type": "string", "minLength": 1 },
    "registry_version": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "verification_mode": { "type": "string", "minLength": 1 },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/source" }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "citation_key",
        "title",
        "source_type",
        "authority_level",
        "url",
        "archived_url",
        "authors",
        "organization",
        "publication_date",
        "version",
        "accessed_at",
        "verification_status",
        "supports_claim_ids",
        "supported_statements",
        "caveats",
        "replacement_or_preferred_source",
        "notes"
      ],
      "properties": {
        "source_id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "citation_key": { "type": "string", "pattern": "^[a-z0-9_]+$" },
        "title": { "type": "string", "minLength": 1 },
        "source_type": {
          "type": "string",
          "enum": [
            "academic_paper",
            "official_standard",
            "official_documentation",
            "regulation",
            "security_guidance",
            "product_documentation",
            "secondary_source",
            "preprint",
            "other"
          ]
        },
        "authority_level": {
          "type": "string",
          "enum": ["primary", "canonical", "secondary", "unverified"]
        },
        "url": { "type": "string", "minLength": 1 },
        "archived_url": { "type": "string" },
        "authors": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "organization": { "type": "string" },
        "publication_date": { "type": "string" },
        "version": { "type": "string" },
        "accessed_at": { "type": "string", "minLength": 1 },
        "verification_status": {
          "type": "string",
          "enum": ["verified", "partially_verified", "unverified", "deprecated"]
        },
        "supports_claim_ids": {
          "type": "array",
          "items": { "type": "string", "pattern": "^C[0-9]+$" }
        },
        "supported_statements": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "caveats": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "replacement_or_preferred_source": { "type": "string" },
        "notes": { "type": "string" }
      }
    }
  }
}
