{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/asiep/v0.1/interfaces/asiep_import_result.schema.json",
  "title": "ASIEP Import Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profile",
    "profile_version",
    "import_id",
    "source_type",
    "valid",
    "output_bundle_dir",
    "evidence_record_path",
    "bundle_manifest_path",
    "generated_artifacts",
    "mapped_fields",
    "unmapped_fields",
    "errors",
    "warnings",
    "revalidation_commands"
  ],
  "properties": {
    "profile": { "const": "ASIEP" },
    "profile_version": { "const": "0.1.0" },
    "import_id": { "type": "string" },
    "source_type": { "type": "string" },
    "valid": { "type": "boolean" },
    "output_bundle_dir": { "type": "string" },
    "evidence_record_path": { "type": "string" },
    "bundle_manifest_path": { "type": "string" },
    "generated_artifacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/generated_artifact" }
    },
    "mapped_fields": {
      "type": "array",
      "items": { "$ref": "#/$defs/mapped_field" }
    },
    "unmapped_fields": {
      "type": "array",
      "items": { "type": "string" }
    },
    "errors": {
      "type": "array",
      "items": { "$ref": "#/$defs/error" }
    },
    "warnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/warning" }
    },
    "revalidation_commands": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  },
  "$defs": {
    "repairability": {
      "type": "string",
      "enum": [
        "auto_fixable",
        "agent_fixable",
        "external_evidence_required",
        "human_required",
        "not_fixable"
      ]
    },
    "generated_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "uri", "path", "role", "media_type", "digest"],
      "properties": {
        "artifact_id": { "type": "string", "minLength": 1 },
        "uri": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "media_type": { "type": "string", "minLength": 1 },
        "digest": { "type": "string", "pattern": "^sha256:[a-fA-F0-9]{64}$" }
      }
    },
    "mapped_field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_path", "target_path", "role"],
      "properties": {
        "source_path": { "type": "string", "minLength": 1 },
        "target_path": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "severity", "message", "json_path", "json_pointer", "remediation_hint", "repairability"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "severity": { "enum": ["error", "warning", "info"] },
        "message": { "type": "string", "minLength": 1 },
        "json_path": { "type": "string", "minLength": 1 },
        "json_pointer": { "type": "string" },
        "remediation_hint": { "type": "string", "minLength": 1 },
        "repairability": { "$ref": "#/$defs/repairability" }
      }
    },
    "warning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "severity", "message", "json_path", "json_pointer", "remediation_hint", "repairability"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "severity": { "enum": ["warning", "info"] },
        "message": { "type": "string", "minLength": 1 },
        "json_path": { "type": "string", "minLength": 1 },
        "json_pointer": { "type": "string" },
        "remediation_hint": { "type": "string", "minLength": 1 },
        "repairability": { "$ref": "#/$defs/repairability" }
      }
    }
  }
}
